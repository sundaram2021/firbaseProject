# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------
# Better Auth
# Generate a secret with:  openssl rand -base64 32
# ------------------------------------------------------------------
BETTER_AUTH_SECRET=replace_with_a_32_char_minimum_random_string
BETTER_AUTH_URL=http://localhost:3000

# ------------------------------------------------------------------
# Google OAuth  (https://console.cloud.google.com/apis/credentials)
# Add this Authorized redirect URI in the Google console:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_DOMAIN/api/auth/callback/google   (for production)
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------
# Supabase Postgres
# App runtime: use the Transaction pooler (port 6543).
#   Project Settings -> Database -> Connection string -> "Transaction pooler"
# For migrations (drizzle-kit) you may swap in the DIRECT connection (5432).
# ------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ------------------------------------------------------------------
# Stripe  (https://dashboard.stripe.com/apikeys)
# ------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ------------------------------------------------------------------
# Production notes
# ------------------------------------------------------------------
# * Set NEXT_PUBLIC_APP_URL to your real domain — it also drives SEO
#   (robots.txt / sitemap.xml), canonical metadata and Better Auth
#   trusted origins.
# * After deploying, run `pnpm db:push` (or db:generate + db:migrate):
#   it adds the Better Auth `rateLimit` table (DB-backed rate limiting)
#   and the `ip_hash` column on `enquiries`.